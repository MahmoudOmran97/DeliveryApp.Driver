<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Driver.ViewModels"
             xmlns:m="clr-namespace:DeliveryApp.Driver.Models"
             xmlns:controls="clr-namespace:DeliveryApp.Driver.Controls"
             xmlns:loc="clr-namespace:DeliveryApp.Driver.Converters"
             x:Class="DeliveryApp.Driver.Views.AvailableOrdersPage"
             x:DataType="vm:AvailableOrdersViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F8F9FA">

	<Grid RowDefinitions="Auto,*,Auto">

		<!-- Header -->
        <Grid RowDefinitions="Auto,*">

            <!-- Header (no back button — this is a Tab now) -->
            <Grid Grid.Row="0" BackgroundColor="#FF5722"
           Padding="20,52,20,16"
           ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
					<Label Text="{loc:Loc Key=AvailableOrders}" FontFamily="CairoBold" FontSize="22" TextColor="White"/>
					<Label Text="{Binding OrdersCount}"
						   FontFamily="CairoRegular" FontSize="13" TextColor="#FFCCBC"/>
				</VerticalStackLayout>
				<Button Grid.Column="1"
						Text="{loc:Loc Key=Refresh}"
						Command="{Binding LoadCommand}"
						BackgroundColor="Transparent"
						TextColor="White"
						FontFamily="CairoBold" FontSize="14"/>
			</Grid>
		</Grid>

		<!-- Orders List -->
		<RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
			<CollectionView ItemsSource="{Binding Orders}"
                            EmptyView="{loc:Loc Key=NoAvailableOrders}"
                            Margin="0,8">
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="m:AvailableOrder">
						<Border Margin="16,6" BackgroundColor="White"
                                StrokeShape="RoundRectangle 16" Stroke="Transparent"
                                Shadow="{Shadow Brush=Black, Offset='0,2', Radius=8, Opacity=0.08}"
                                Padding="16">
							<VerticalStackLayout Spacing="12">

								<!-- Top: Restaurant + Time -->
								<Grid ColumnDefinitions="*,Auto">
									<HorizontalStackLayout Grid.Column="0" Spacing="8">
										<Label Text="🏪" FontSize="18" VerticalOptions="Center"/>
										<Label Text="{Binding RestaurantName}"
                                               FontFamily="CairoBold" FontSize="15" TextColor="#212121"
                                               VerticalOptions="Center"/>
									</HorizontalStackLayout>
									<Label Grid.Column="1" Text="{Binding TimeAgoText}"
                                           FontFamily="CairoRegular" FontSize="12" TextColor="#9E9E9E"
                                           VerticalOptions="Center"/>
								</Grid>

								<!-- Divider -->
								<BoxView HeightRequest="1" Color="#F5F5F5"/>

								<!-- Delivery Address -->
								<HorizontalStackLayout Spacing="8">
									<Label Text="📍" FontSize="14" VerticalOptions="Start"/>
									<Label Text="{Binding DeliveryAddress}"
                                           FontFamily="CairoRegular" FontSize="13" TextColor="#616161"
                                           LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand"/>
								</HorizontalStackLayout>

								<!-- Stats Row -->
								<Grid ColumnDefinitions="*,*,*">
									<VerticalStackLayout Grid.Column="0" Spacing="2">
										<Label Text="{loc:Loc Key=OrderEarning}" FontFamily="CairoRegular" FontSize="11" TextColor="#9E9E9E"/>
										<Label Text="{Binding DeliveryFeeText}"
                                               FontFamily="CairoBold" FontSize="16" TextColor="#4CAF50"/>
									</VerticalStackLayout>
									<VerticalStackLayout Grid.Column="1" Spacing="2">
										<Label Text="{loc:Loc Key=OrderTotal}" FontFamily="CairoRegular" FontSize="11" TextColor="#9E9E9E"/>
										<Label Text="{Binding TotalAmountText}"
                                               FontFamily="CairoBold" FontSize="15" TextColor="#212121"/>
									</VerticalStackLayout>
									<VerticalStackLayout Grid.Column="2" Spacing="2">
										<Label Text="{loc:Loc Key=ItemsCount}" FontFamily="CairoRegular" FontSize="11" TextColor="#9E9E9E"/>
										<Label Text="{Binding ItemCountText}"
                                               FontFamily="CairoBold" FontSize="15" TextColor="#212121"/>
									</VerticalStackLayout>
								</Grid>

								<!-- Accept Button -->
								<Button Text="{loc:Loc Key=AcceptOrder}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FF5722" TextColor="White"
                                        FontFamily="CairoBold" FontSize="14"
                                        HeightRequest="44" CornerRadius="10"
                                        Clicked="OnAcceptClicked"/>

							</VerticalStackLayout>
						</Border>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</RefreshView>

		<!-- Busy overlay -->
		<Grid Grid.Row="1" IsVisible="{Binding IsBusy}"
              BackgroundColor="#80FFFFFF">
			<ActivityIndicator IsRunning="True" Color="#FF5722"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
		</Grid>

		<controls:CurvedBottomBar Grid.Row="2" SelectedTab="orders"
                                 HorizontalOptions="Fill" Margin="0" Padding="0"/>
	</Grid>
</ContentPage>
