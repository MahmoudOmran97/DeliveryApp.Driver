<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Driver.ViewModels"
             xmlns:m="clr-namespace:DeliveryApp.Driver.Models"
             x:Class="DeliveryApp.Driver.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

	<RefreshView Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
		<ScrollView>
			<VerticalStackLayout Spacing="0">

				<!-- ── HEADER ── -->
				<Grid BackgroundColor="#FF5722" Padding="20,52,20,20" ColumnDefinitions="*,48">

					<VerticalStackLayout Grid.Column="0" Spacing="3">
						<Label Text="🛵 Driver App"
                               FontFamily="CairoRegular" FontSize="12" TextColor="#FFCCBC"/>
						<Label FontFamily="CairoBold" FontSize="20" TextColor="White">
							<Label.FormattedText>
								<FormattedString>
									<Span Text="Hello, "/>
									<Span Text="{Binding GreetingName}"/>
									<Span Text=" 👋"/>
								</FormattedString>
							</Label.FormattedText>
						</Label>
					</VerticalStackLayout>

					<!-- Notifications bell -->
					<Border Grid.Column="1" BackgroundColor="White"
                            StrokeShape="RoundRectangle 24" Stroke="Transparent"
                            WidthRequest="44" HeightRequest="44"
                            HorizontalOptions="End" VerticalOptions="Center">
						<Label Text="🔔" FontSize="22"
                               HorizontalOptions="Center" VerticalOptions="Center">
							<Label.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnNotificationsTapped"/>
							</Label.GestureRecognizers>
						</Label>
					</Border>
				</Grid>

				<!-- ── STATUS CARD ── -->
				<Border Margin="16,-24,16,0" BackgroundColor="White"
                        StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        Shadow="{Shadow Brush=Black, Offset='0,2', Radius=8, Opacity=0.08}"
                        Padding="20,16">
					<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,12,Auto">

						<Label Grid.Row="0" Grid.Column="0"
                               Text="Status" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>

						<Border Grid.Row="0" Grid.Column="1"
                                BackgroundColor="{Binding IsOnline, Converter={StaticResource BoolToOnlineColorConverter}}"
                                StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                Padding="12,4">
							<Label Text="{Binding Profile.StatusText}"
                                   FontFamily="CairoBold" FontSize="13" TextColor="White"/>
						</Border>

						<Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                               FontFamily="CairoRegular" FontSize="12" TextColor="#FF9800"
                               IsVisible="{Binding IsNotVerified}"
                               Text="⚠️ Account pending verification by admin"/>

						<Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Text="{Binding OnlineButtonText}"
                                BackgroundColor="{Binding OnlineButtonColor}"
                                TextColor="White"
                                FontFamily="CairoBold" FontSize="15"
                                HeightRequest="46"
                                CornerRadius="12"
                                Command="{Binding ToggleOnlineCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                IsVisible="{Binding IsNotVerified, Converter={StaticResource InvertedBool}}"
                                Margin="0,4,0,0"/>
					</Grid>
				</Border>

				<VerticalStackLayout Padding="16,20,16,0" Spacing="16">

					<!-- ── ACTIVE ORDER CARD ── -->
					<Border IsVisible="{Binding HasActiveOrder}"
                            BackgroundColor="White" StrokeShape="RoundRectangle 16"
                            Stroke="#FF5722" StrokeThickness="2"
                            Shadow="{Shadow Brush=Black, Offset='0,2', Radius=8, Opacity=0.08}"
                            Padding="16">
						<VerticalStackLayout Spacing="12">

							<HorizontalStackLayout Spacing="8">
								<Label Text="📦" FontSize="20"/>
								<Label Text="Active Delivery"
                                       FontFamily="CairoBold" FontSize="16" TextColor="#212121"
                                       VerticalOptions="Center"/>
							</HorizontalStackLayout>

							<!-- Status badge -->
							<Border BackgroundColor="{Binding ActiveOrder.StatusColor}"
                                    StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                    Padding="12,6" HorizontalOptions="Start">
								<Label Text="{Binding ActiveOrder.StatusText}"
                                       FontFamily="CairoBold" FontSize="13" TextColor="White"/>
							</Border>

							<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
								<VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
									<Label Text="Restaurant" FontFamily="CairoRegular" FontSize="12" TextColor="#9E9E9E"/>
									<Label Text="{Binding ActiveOrder.RestaurantName}"
                                           FontFamily="CairoBold" FontSize="14" TextColor="#212121"/>
								</VerticalStackLayout>
								<VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
									<Label Text="Earning" FontFamily="CairoRegular" FontSize="12" TextColor="#9E9E9E"/>
									<Label Text="{Binding ActiveOrder.DeliveryFeeText}"
                                           FontFamily="CairoBold" FontSize="14" TextColor="#4CAF50"/>
								</VerticalStackLayout>
							</Grid>

							<Label Text="{Binding ActiveOrder.DeliveryAddress}"
                                   FontFamily="CairoRegular" FontSize="13" TextColor="#757575"
                                   LineBreakMode="TailTruncation"/>

							<Button Text="View Delivery Details →"
                                    Command="{Binding GoToDeliveryCommand}"
                                    BackgroundColor="#FF5722" TextColor="White"
                                    FontFamily="CairoBold" FontSize="14"
                                    HeightRequest="44" CornerRadius="10"/>
						</VerticalStackLayout>
					</Border>

					<!-- ── TODAY STATS ── -->
					<Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            Shadow="{Shadow Brush=Black, Offset='0,2', Radius=8, Opacity=0.08}"
                            Padding="16">
						<VerticalStackLayout Spacing="14">
							<Label Text="Today's Stats"
                                   FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>

							<Grid ColumnDefinitions="*,*,*">
								<!-- Deliveries -->
								<VerticalStackLayout Grid.Column="0" Spacing="4"
                                                     HorizontalOptions="Center">
									<Label Text="{Binding TodayEarnings.TotalDeliveries}"
                                           FontFamily="CairoBold" FontSize="28" TextColor="#FF5722"
                                           HorizontalOptions="Center"/>
									<Label Text="Deliveries" FontFamily="CairoRegular" FontSize="12"
                                           TextColor="#757575" HorizontalOptions="Center"/>
								</VerticalStackLayout>

								<!-- Divider -->
								<BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="#F0F0F0"
                                         HorizontalOptions="End" VerticalOptions="Fill" Margin="0,4"/>

								<!-- Earnings -->
								<VerticalStackLayout Grid.Column="1" Spacing="4"
                                                     HorizontalOptions="Center">
									<Label Text="{Binding TodayEarnings.TotalEarningsText}"
                                           FontFamily="CairoBold" FontSize="22" TextColor="#4CAF50"
                                           HorizontalOptions="Center"/>
									<Label Text="Earnings" FontFamily="CairoRegular" FontSize="12"
                                           TextColor="#757575" HorizontalOptions="Center"/>
								</VerticalStackLayout>

								<!-- Divider -->
								<BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#F0F0F0"
                                         HorizontalOptions="End" VerticalOptions="Fill" Margin="0,4"/>

								<!-- Rating -->
								<VerticalStackLayout Grid.Column="2" Spacing="4"
                                                     HorizontalOptions="Center">
									<Label Text="{Binding Profile.RatingText}"
                                           FontFamily="CairoBold" FontSize="22" TextColor="#FF9800"
                                           HorizontalOptions="Center"/>
									<Label Text="Rating" FontFamily="CairoRegular" FontSize="12"
                                           TextColor="#757575" HorizontalOptions="Center"/>
								</VerticalStackLayout>
							</Grid>
						</VerticalStackLayout>
					</Border>

					<!-- ── QUICK ACTIONS ── -->
					<Label Text="Quick Actions"
                           FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>

					<Grid ColumnDefinitions="*,*" ColumnSpacing="12">

						<!-- Available Orders -->
						<Border Grid.Column="0" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="Transparent"
                                Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.06}"
                                Padding="16,14">
							<Border.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnAvailableOrdersTapped"/>
							</Border.GestureRecognizers>
							<VerticalStackLayout Spacing="8" HorizontalOptions="Center">
								<Label Text="📋" FontSize="32" HorizontalOptions="Center"/>
								<Label Text="Available" FontFamily="CairoBold" FontSize="14"
                                       TextColor="#212121" HorizontalOptions="Center"/>
								<Label Text="Orders" FontFamily="CairoRegular" FontSize="12"
                                       TextColor="#757575" HorizontalOptions="Center"/>
							</VerticalStackLayout>
						</Border>

						<!-- Earnings -->
						<Border Grid.Column="1" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="Transparent"
                                Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.06}"
                                Padding="16,14">
							<Border.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnEarningsTapped"/>
							</Border.GestureRecognizers>
							<VerticalStackLayout Spacing="8" HorizontalOptions="Center">
								<Label Text="💰" FontSize="32" HorizontalOptions="Center"/>
								<Label Text="My" FontFamily="CairoBold" FontSize="14"
                                       TextColor="#212121" HorizontalOptions="Center"/>
								<Label Text="Earnings" FontFamily="CairoRegular" FontSize="12"
                                       TextColor="#757575" HorizontalOptions="Center"/>
							</VerticalStackLayout>
						</Border>
					</Grid>

					<BoxView HeightRequest="20" Color="Transparent"/>

				</VerticalStackLayout>
			</VerticalStackLayout>
		</ScrollView>
	</RefreshView>
</ContentPage>
