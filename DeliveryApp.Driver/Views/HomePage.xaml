<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Driver.ViewModels"
             xmlns:m="clr-namespace:DeliveryApp.Driver.Models"
             xmlns:controls="clr-namespace:DeliveryApp.Driver.Controls"
             xmlns:loc="clr-namespace:DeliveryApp.Driver.Converters"
             x:Class="DeliveryApp.Driver.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F8F9FA">

	<Grid RowDefinitions="*,Auto">
	<RefreshView Grid.Row="0" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
		<ScrollView>
			<VerticalStackLayout Spacing="0">

				<!-- ── HEADER ── -->
				<Grid BackgroundColor="#FF5722" Padding="20,52,20,20" ColumnDefinitions="*,48">

					<VerticalStackLayout Grid.Column="0" Spacing="3">
						<Label Text="{loc:Loc Key=DriverApp}"
                               FontFamily="CairoRegular" FontSize="12" TextColor="#FFCCBC"/>
						<Label FontFamily="CairoBold" FontSize="20" TextColor="White">
							<Label.FormattedText>
								<FormattedString>
									<Span Text="{loc:Loc Key=Hello}"/>
									<Span Text=", "/>
									<Span Text="{Binding GreetingName}"/>
									<Span Text=" 👋"/>
								</FormattedString>
							</Label.FormattedText>
						</Label>
					</VerticalStackLayout>

					<!-- Notifications bell -->
					<Border Grid.Column="1" BackgroundColor="White"
                            StrokeShape="RoundRectangle 24" Stroke="Transparent"
                            WidthRequest="44" HeightRequest="44"
                            HorizontalOptions="End" VerticalOptions="Center">
						<Label Text="🔔" FontSize="22"
                               HorizontalOptions="Center" VerticalOptions="Center">
							<Label.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnNotificationsTapped"/>
							</Label.GestureRecognizers>
						</Label>
					</Border>
				</Grid>

				<!-- ── STATUS CARD ── -->
				<Border Margin="16,-24,16,0" BackgroundColor="White"
                        StrokeShape="RoundRectangle 16" Stroke="Transparent"
                        Shadow="{Shadow Brush=Black, Offset='0,2', Radius=8, Opacity=0.08}"
                        Padding="20,16">
					<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,12,Auto">

						<Label Grid.Row="0" Grid.Column="0"
                               Text="{loc:Loc Key=Status}" FontFamily="CairoRegular" FontSize="13" TextColor="#757575"/>

						<Border Grid.Row="0" Grid.Column="1"
                                BackgroundColor="{Binding IsOnline, Converter={StaticResource BoolToOnlineColorConverter}}"
                                StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                Padding="12,4">
							<Label Text="{Binding Profile.StatusText}"
                                   FontFamily="CairoBold" FontSize="13" TextColor="White"/>
						</Border>

						<Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                               FontFamily="CairoRegular" FontSize="12" TextColor="#FF9800"
                               IsVisible="{Binding IsNotVerified}"
                               Text="{loc:Loc Key=PendingVerification}"/>

						<Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Text="{Binding OnlineButtonText}"
                                BackgroundColor="{Binding OnlineButtonColor}"
                                TextColor="White"
                                FontFamily="CairoBold" FontSize="15"
                                HeightRequest="46"
                                CornerRadius="12"
                                Command="{Binding ToggleOnlineCommand}"
                                IsEnabled="{Binding IsNotBusy}"
                                IsVisible="{Binding IsNotVerified, Converter={StaticResource InvertedBool}}"
                                Margin="0,4,0,0"/>
					</Grid>
				</Border>

				<VerticalStackLayout Padding="16,20,16,0" Spacing="16">

					<!-- ── ACTIVE ORDERS ── -->
					<VerticalStackLayout IsVisible="{Binding HasActiveOrders}" Spacing="8">
						<HorizontalStackLayout Spacing="8">
							<Label Text="📦" FontSize="20"/>
							<Label Text="{loc:Loc Key=ActiveDeliveries}"
                                   FontFamily="CairoBold" FontSize="16" TextColor="#212121"
                                   VerticalOptions="Center"/>
						</HorizontalStackLayout>

						<CollectionView ItemsSource="{Binding ActiveOrders}" SelectionMode="None">
							<CollectionView.ItemTemplate>
								<DataTemplate x:DataType="m:DriverOrder">
									<Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                                            Stroke="#FF5722" StrokeThickness="1.5"
                                            Shadow="{Shadow Brush=Black, Offset='0,2', Radius=8, Opacity=0.08}"
                                            Padding="14" Margin="0,0,0,8">
										<VerticalStackLayout Spacing="10">
											<Grid ColumnDefinitions="*,Auto">
												<Label Text="{Binding RestaurantName}" Grid.Column="0"
                                                       FontFamily="CairoBold" FontSize="15" TextColor="#212121"
                                                       LineBreakMode="TailTruncation"/>
												<Border Grid.Column="1" BackgroundColor="{Binding StatusColor}"
                                                        Stroke="Transparent" StrokeShape="RoundRectangle 8"
                                                        Padding="10,4">
													<Label Text="{Binding Status}" FontFamily="CairoBold" FontSize="11" TextColor="White"/>
												</Border>
											</Grid>

											<Label Text="{Binding DeliveryAddress}"
                                                   FontFamily="CairoRegular" FontSize="13" TextColor="#757575"
                                                   LineBreakMode="TailTruncation"/>

											<Grid ColumnDefinitions="*,*">
												<VerticalStackLayout Spacing="2">
													<Label Text="{loc:Loc Key=Earning}" FontFamily="CairoRegular" FontSize="11" TextColor="#9E9E9E"/>
													<Label Text="{Binding EarningText}" FontFamily="CairoBold" FontSize="14" TextColor="#4CAF50"/>
												</VerticalStackLayout>
												<VerticalStackLayout Grid.Column="1" Spacing="2">
													<Label Text="{loc:Loc Key=OrderTotal}" FontFamily="CairoRegular" FontSize="11" TextColor="#9E9E9E"/>
													<Label Text="{Binding TotalText}" FontFamily="CairoBold" FontSize="14" TextColor="#212121"/>
												</VerticalStackLayout>
											</Grid>

											<Button Text="{loc:Loc Key=ViewDetails}"
                                                    BackgroundColor="#FFF3EF"
                                                    TextColor="#FF5722"
                                                    FontFamily="CairoBold"
                                                    FontSize="13"
                                                    HeightRequest="40"
                                                    CornerRadius="10"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=OpenOrderDetailsCommand}"
                                                    CommandParameter="{Binding .}"/>
										</VerticalStackLayout>
									</Border>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>
					</VerticalStackLayout>

					<!-- ── TODAY STATS ── -->
					<Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            Shadow="{Shadow Brush=Black, Offset='0,2', Radius=8, Opacity=0.08}"
                            Padding="16">
						<VerticalStackLayout Spacing="14">
							<Label Text="{loc:Loc Key=TodayStats}"
                                   FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>

							<Grid ColumnDefinitions="*,*,*">
								<!-- Deliveries -->
								<VerticalStackLayout Grid.Column="0" Spacing="4"
                                                     HorizontalOptions="Center">
									<Label Text="{Binding TodayEarnings.TotalDeliveries}"
                                           FontFamily="CairoBold" FontSize="28" TextColor="#FF5722"
                                           HorizontalOptions="Center"/>
									<Label Text="{loc:Loc Key=Deliveries}" FontFamily="CairoRegular" FontSize="12"
                                           TextColor="#757575" HorizontalOptions="Center"/>
								</VerticalStackLayout>

								<!-- Divider -->
								<BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="#F0F0F0"
                                         HorizontalOptions="End" VerticalOptions="Fill" Margin="0,4"/>

								<!-- Earnings -->
								<VerticalStackLayout Grid.Column="1" Spacing="4"
                                                     HorizontalOptions="Center">
									<Label Text="{Binding TodayEarnings.TotalEarningsText}"
                                           FontFamily="CairoBold" FontSize="22" TextColor="#4CAF50"
                                           HorizontalOptions="Center"/>
									<Label Text="{loc:Loc Key=Earnings}" FontFamily="CairoRegular" FontSize="12"
                                           TextColor="#757575" HorizontalOptions="Center"/>
								</VerticalStackLayout>

								<!-- Divider -->
								<BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#F0F0F0"
                                         HorizontalOptions="End" VerticalOptions="Fill" Margin="0,4"/>

								<!-- Rating -->
								<VerticalStackLayout Grid.Column="2" Spacing="4"
                                                     HorizontalOptions="Center">
									<Label Text="{Binding Profile.RatingText}"
                                           FontFamily="CairoBold" FontSize="22" TextColor="#FF9800"
                                           HorizontalOptions="Center"/>
									<Label Text="{loc:Loc Key=Rating}" FontFamily="CairoRegular" FontSize="12"
                                           TextColor="#757575" HorizontalOptions="Center"/>
								</VerticalStackLayout>
							</Grid>
						</VerticalStackLayout>
					</Border>

					<!-- ── QUICK ACTIONS ── -->
					<Label Text="{loc:Loc Key=QuickActions}"
                           FontFamily="CairoBold" FontSize="16" TextColor="#212121"/>

					<Grid ColumnDefinitions="*,*" ColumnSpacing="12">

						<!-- Available Orders -->
						<Border Grid.Column="0" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="Transparent"
                                Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.06}"
                                Padding="16,14">
							<Border.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnAvailableOrdersTapped"/>
							</Border.GestureRecognizers>
							<VerticalStackLayout Spacing="8" HorizontalOptions="Center">
								<Label Text="📋" FontSize="32" HorizontalOptions="Center"/>
								<Label Text="{loc:Loc Key=Available}" FontFamily="CairoBold" FontSize="14"
                                       TextColor="#212121" HorizontalOptions="Center"/>
								<Label Text="{loc:Loc Key=Orders}" FontFamily="CairoRegular" FontSize="12"
                                       TextColor="#757575" HorizontalOptions="Center"/>
							</VerticalStackLayout>
						</Border>

						<!-- Earnings -->
						<Border Grid.Column="1" BackgroundColor="White"
                                StrokeShape="RoundRectangle 14" Stroke="Transparent"
                                Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.06}"
                                Padding="16,14">
							<Border.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnEarningsTapped"/>
							</Border.GestureRecognizers>
							<VerticalStackLayout Spacing="8" HorizontalOptions="Center">
								<Label Text="💰" FontSize="32" HorizontalOptions="Center"/>
								<Label Text="{loc:Loc Key=My}" FontFamily="CairoBold" FontSize="14"
                                       TextColor="#212121" HorizontalOptions="Center"/>
								<Label Text="{loc:Loc Key=Earnings}" FontFamily="CairoRegular" FontSize="12"
                                       TextColor="#757575" HorizontalOptions="Center"/>
							</VerticalStackLayout>
						</Border>
					</Grid>

					<BoxView HeightRequest="20" Color="Transparent"/>

				</VerticalStackLayout>
			</VerticalStackLayout>
		</ScrollView>
	</RefreshView>
	<controls:CurvedBottomBar Grid.Row="1" SelectedTab="home"
                             HorizontalOptions="Fill" Margin="0" Padding="0"/>
	</Grid>
</ContentPage>
