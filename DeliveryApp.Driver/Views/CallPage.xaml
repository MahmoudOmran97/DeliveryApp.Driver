<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DeliveryApp.Driver.ViewModels"
             x:Class="DeliveryApp.Driver.Views.CallPage"
             x:DataType="vm:CallViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#1B1B1F">

    <Grid RowDefinitions="*,Auto" Padding="24,80,24,60">

        <VerticalStackLayout Grid.Row="0" Spacing="16" VerticalOptions="Center" HorizontalOptions="Center">
            <Frame BackgroundColor="#FF5722"
       CornerRadius="60"
       WidthRequest="120" HeightRequest="120"
       Padding="0"
       HasShadow="False"
       HorizontalOptions="Center">
                <Label Text="📞" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Frame>

            <Label Text="{Binding OtherPartyName}" FontFamily="CairoBold" FontSize="24"
                   TextColor="White" HorizontalOptions="Center"/>

            <Label Text="{Binding StatusText}" FontFamily="CairoRegular" FontSize="16"
                   TextColor="#B0B0B0" HorizontalOptions="Center"/>

            <Label Text="{Binding DurationText}" FontFamily="CairoRegular" FontSize="16"
                   TextColor="#4CAF50" HorizontalOptions="Center"
                   IsVisible="{Binding IsConnected}"/>
        </VerticalStackLayout>

        <!-- Incoming call: Accept / Reject -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="20" IsVisible="{Binding IsRinging}">
            <Button Grid.Column="0" Text="رفض" BackgroundColor="#E53935" TextColor="White"
                    FontFamily="CairoBold" CornerRadius="30" HeightRequest="60"
                    Command="{Binding RejectCommand}"/>
            <Button Grid.Column="1" Text="قبول" BackgroundColor="#43A047" TextColor="White"
                    FontFamily="CairoBold" CornerRadius="30" HeightRequest="60"
                    Command="{Binding AcceptCommand}"/>
        </Grid>

        <!-- Outgoing call (ringing at the other side): Cancel -->
        <Button Grid.Row="1" Text="إلغاء" BackgroundColor="#E53935" TextColor="White"
                FontFamily="CairoBold" CornerRadius="30" HeightRequest="60"
                IsVisible="{Binding IsCalling}"
                Command="{Binding CancelCommand}"/>

        <!-- Connected: End call -->
        <Button Grid.Row="1" Text="إنهاء المكالمة" BackgroundColor="#E53935" TextColor="White"
                FontFamily="CairoBold" CornerRadius="30" HeightRequest="60"
                IsVisible="{Binding IsConnected}"
                Command="{Binding EndCallCommand}"/>
    </Grid>
</ContentPage>
