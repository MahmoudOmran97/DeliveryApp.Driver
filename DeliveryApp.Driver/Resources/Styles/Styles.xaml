<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:conv="clr-namespace:DeliveryApp.Driver.Converters">

    <!-- Converters (global) -->
    <conv:InvertedBoolConverter  x:Key="InvertBool" />
    <conv:InvertedBoolConverter  x:Key="InvertedBoolConverter" />
    <conv:BoolToColorConverter   x:Key="BoolToColorConverter" />

    <conv:IntToBoolConverter     x:Key="IntToBool" />

    <conv:IsOpenToColorConverter x:Key="IsOpenColor" />

    <conv:IsReadToColorConverter x:Key="IsReadColor" />

    <conv:NullOrEmptyToBoolConverter x:Key="HasImage" />


    <!-- ── Implicit styles: تمنع اللون الأزرق الافتراضي لـ MAUI ── -->
    <Style TargetType="Label" ApplyToDerivedTypes="True">
        <Setter Property="TextColor"  Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="CairoRegular" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Gray400}" />
        <Setter Property="FontFamily"       Value="CairoRegular" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Gray400}" />
        <Setter Property="FontFamily"       Value="CairoRegular" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor"        Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Gray400}" />
        <Setter Property="FontFamily"       Value="CairoRegular" />
        <Setter Property="BackgroundColor"  Value="Transparent" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">

        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />

    </Style>

    <Style x:Key="PrimaryBtn" TargetType="Button">

        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />

        <Setter Property="TextColor"       Value="White" />

        <Setter Property="FontFamily"      Value="CairoBold" />

        <Setter Property="FontSize"        Value="16" />

        <Setter Property="CornerRadius"    Value="14" />

        <Setter Property="HeightRequest"   Value="52" />

    </Style>

    <Style x:Key="OutlineBtn" TargetType="Button">

        <Setter Property="BackgroundColor" Value="Transparent" />

        <Setter Property="TextColor"       Value="{StaticResource Primary}" />

        <Setter Property="BorderColor"     Value="{StaticResource Primary}" />

        <Setter Property="BorderWidth"     Value="2" />

        <Setter Property="FontFamily"      Value="CairoBold" />

        <Setter Property="FontSize"        Value="16" />

        <Setter Property="CornerRadius"    Value="14" />

        <Setter Property="HeightRequest"   Value="52" />

    </Style>

    <Style x:Key="Card" TargetType="Border">

        <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />

        <Setter Property="StrokeShape"     Value="RoundRectangle 16" />

        <Setter Property="Stroke"          Value="Transparent" />

        <Setter Property="Padding"         Value="16" />

        <Setter Property="Shadow">

            <Setter.Value>

                <Shadow Brush="Black" Offset="0,2" Opacity="0.07" Radius="12" />

            </Setter.Value>

        </Setter>

    </Style>

    <Style x:Key="InputBorder" TargetType="Border">

        <Setter Property="BackgroundColor" Value="White" />

        <Setter Property="StrokeShape"     Value="RoundRectangle 12" />

        <Setter Property="Stroke"          Value="{StaticResource Divider}" />

        <Setter Property="StrokeThickness" Value="1" />

        <Setter Property="Padding"         Value="14,0" />

    </Style>

    <Style x:Key="H1" TargetType="Label">

        <Setter Property="FontFamily" Value="CairoBold" />

        <Setter Property="FontSize"   Value="24" />

        <Setter Property="TextColor"  Value="{StaticResource TextPrimary}" />

    </Style>

    <Style x:Key="H2" TargetType="Label">

        <Setter Property="FontFamily" Value="CairoBold" />

        <Setter Property="FontSize"   Value="17" />

        <Setter Property="TextColor"  Value="{StaticResource TextPrimary}" />

    </Style>

    <Style x:Key="Body" TargetType="Label">

        <Setter Property="FontFamily" Value="CairoRegular" />

        <Setter Property="FontSize"   Value="14" />

        <Setter Property="TextColor"  Value="{StaticResource TextPrimary}" />

    </Style>

    <Style x:Key="Caption" TargetType="Label">

        <Setter Property="FontFamily" Value="CairoRegular" />

        <Setter Property="FontSize"   Value="12" />

        <Setter Property="TextColor"  Value="{StaticResource TextSecondary}" />

    </Style>


</ResourceDictionary>
